# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will NOT be committed.

# Hugging Face API token (required only for private/gated models).
# Public models like all-MiniLM-L6-v2 and t5-small work WITHOUT a token.
# If you get a 403 / "token expired or invalid" error, generate a new token at:
#   https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override the embedding model (path or HF repo id)
# EMB_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: override the generation model (path or HF repo id)
# GEN_MODEL=google-t5/t5-small
